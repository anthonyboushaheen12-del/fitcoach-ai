# Copy to `.env.local` for local development. Never commit `.env.local`.

# Supabase (public — safe to expose in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: API routes (e.g. /api/progress-photo) use this to bypass RLS when set.
# Get from Supabase Dashboard → Project Settings → API → service_role (secret).
# Required for production on Vercel if you want reliable server-side inserts without RLS blocking.
# Add the same variable in Vercel → Project → Settings → Environment Variables (Production + Preview).
SUPABASE_SERVICE_ROLE_KEY=
